public-hoist-pattern[]=*react*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
shamefully-hoist=false
# Evita que pnpm 11 corra `pnpm install` antes de cada script y aborte
# en entornos no interactivos (CI, contenedores) con
# ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY al ejecutar `pnpm dev`.
verify-deps-before-run=false
